# PORT=4000

# JWT_SECRET=change-me-too
# JWT_EXPIRES_IN=7d
# # Backend-owned toggle for mock vs real data
# MOCK_API=false
# # Optional fallback key also supported by backend:
# # VITE_MOCK_API=true

# Cricbuzz scraper API base URL. Required only when LIVE_SCORE_AUTO_UPDATE=ON.
# LIVE_SCORE_API_URL=change-me

# Master switch for external scraper calls. ON allows /matches/live, /playing-xi, and /scorecard calls.
# OFF still allows MyXI DB-only status maintenance, but no scraper calls.
# LIVE_SCORE_AUTO_UPDATE=OFF

# Page-load/on-demand scraper throttle. 300000 = at most once every 5 minutes.
# Set to 0 to allow every page-load request to attempt scraper sync.
# LIVE_SCORE_ON_DEMAND_MIN_INTERVAL_MS=300000

# Scraper status value treated as live for score writes.
# LIVE_SCORE_PROVIDER_LIVE_STATUS=Live

# MyXI DB stale fallback: started/inprogress matches become completed after this many hours.
# This does not call the scraper.
# LIVE_SCORE_AUTO_COMPLETE_AFTER_HOURS=24
